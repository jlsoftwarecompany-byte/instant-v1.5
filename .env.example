# Database
PORT=3000

# Push notifications (auto-generated per-session if blank)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── v1.5 Strategic Upgrade ─────────────────────────────────────────────
# JWT signing secret (HS256). Set in production; v1.5 generates an ephemeral
# key per-process when blank.
JWT_SECRET=

# AI Messaging Layer (Strategic Plan §4) — uses @google/genai
VITE_GEMINI_API_KEY=

# Backblaze B2 (optional; falls back to local ./media-store when blank)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
